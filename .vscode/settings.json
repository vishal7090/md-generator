{
  // Single-folder workspace (repo root): Pylance uses pyrightconfig.json for each package.
  // For Test Explorer on all tools, open md-generator.code-workspace instead.
  "python.languageServer": "Pylance",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.typeCheckingMode": "basic",
  "python.terminal.activateEnvironment": true,
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["--rootdir=zip-to-md", "zip-to-md/tests"],

  "[python]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [88, 100]
  }
}
